<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biznes məlumatları"
            android:textSize="24sp"
            android:textColor="#1A1A1A"
            android:layout_marginTop="60dp"
            android:fontFamily="@font/poppins_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biznesinizi doğrulamaq üçün məlumatları qeyd edin"
            android:textSize="14sp"
            android:textColor="#999999"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_regular"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelShopName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Butiq adı"
            android:fontFamily="@font/poppins_regular"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardShopName"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/labelShopName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/bgIconShop"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="#F8F8F8"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/botique_icon"
                    app:tint="#CCCCCC"
                    app:layout_constraintTop_toTopOf="@id/bgIconShop"
                    app:layout_constraintBottom_toBottomOf="@id/bgIconShop"
                    app:layout_constraintStart_toStartOf="@id/bgIconShop"
                    app:layout_constraintEnd_toEndOf="@id/bgIconShop" />

                <EditText
                    android:id="@+id/etShopName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Butiq adı"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/bgIconShop" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/labelUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="İstifadəçi adı"
            android:fontFamily="@font/poppins_regular"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardShopName"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardUsername"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/labelUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/bgIconUser"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="#F8F8F8"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/botique_icon"
                    app:tint="#CCCCCC"
                    app:layout_constraintTop_toTopOf="@id/bgIconUser"
                    app:layout_constraintBottom_toBottomOf="@id/bgIconUser"
                    app:layout_constraintStart_toStartOf="@id/bgIconUser"
                    app:layout_constraintEnd_toEndOf="@id/bgIconUser" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="İstifadəçi adı"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/bgIconUser" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/labelCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Təsdiq kodu"
            android:fontFamily="@font/poppins_regular"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardUsername"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardVerificationCode"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/labelCode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/bgIconCode"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="#F8F8F8"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/user_icon"
                    app:tint="#CCCCCC"
                    app:layout_constraintTop_toTopOf="@id/bgIconCode"
                    app:layout_constraintBottom_toBottomOf="@id/bgIconCode"
                    app:layout_constraintStart_toStartOf="@id/bgIconCode"
                    app:layout_constraintEnd_toEndOf="@id/bgIconCode" />

                <EditText
                    android:id="@+id/etVerificationCode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Təsdiq kodu"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/bgIconCode" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Növbəti →"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/poppins_regular"
            app:backgroundTint="#B8986C"
            app:cornerRadius="30dp"
            app:layout_constraintTop_toBottomOf="@id/cardVerificationCode"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>