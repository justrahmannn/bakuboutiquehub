<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1ED"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:padding="10dp">

        <TextView
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xoş gəlmisiniz:  "
            android:id="@+id/xosgelmisiniz"
            android:layout_marginTop="15dp"
            android:visibility="gone"
            android:textColor="#B89968"
            android:textSize="16sp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/ad"
            android:visibility="gone"
            android:text="İstifadəçi"
            android:textColor="#B89968"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/xosgelmisiniz"
            app:layout_constraintTop_toTopOf="@id/xosgelmisiniz"
            />


        <LinearLayout
            android:id="@+id/buttonsContainer"
            android:layout_width="250dp"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:padding="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginbutton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:text="Giriş"
                android:textColor="#B89968"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="28dp"
                app:strokeColor="#B89968"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/signupbutton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Qeydiyyat"
                android:textColor="#B89968"
                app:backgroundTint="#F5F1ED"
                app:cornerRadius="28dp"
                app:strokeColor="#B89968"
                app:strokeWidth="2dp" />
        </LinearLayout>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/topElementsBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="buttonsContainer,xosgelmisiniz,ad" />

        <View
            android:id="@+id/dividerLine"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#B89968"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topElementsBarrier" />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_bar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundColor="@color/white"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusTopStart="18dp"
            app:endIconDrawable="@drawable/search_icon"
            app:endIconMode="custom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerLine">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Yeni dəblər axtarın" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/bannerViewPager"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/search_bar" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/bannerIndicator"
            android:layout_width="wrap_content"
            android:layout_height="12dp"
            android:layout_marginTop="12dp"
            android:background="@android:color/transparent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bannerViewPager"
            app:tabBackground="@drawable/tab_indicator_selector"
            app:tabGravity="center"
            app:tabIndicatorHeight="0dp"
            app:tabMaxWidth="12dp" />
        
        <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:nestedScrollingEnabled="false"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bannerIndicator"
        tools:listitem="@layout/item_category" />

        <TextView
            android:id="@+id/yeni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/rvCategories"
            />
        <TextView
            android:id="@+id/moreNewIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daha çox"
            android:textSize="14sp"
            android:textColor="#B89968"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/yeni"
            app:layout_constraintBottom_toBottomOf="@id/yeni"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNewIn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/yeni"
            tools:listitem="@layout/item_product" />

        <TextView
            android:id="@+id/trending"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trenddə olanlar"
            app:layout_constraintTop_toBottomOf="@id/rvNewIn"
            android:textSize="18sp"
            />

        <TextView
            android:id="@+id/moreTrend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daha çox"
            android:textSize="14sp"
            android:textColor="#B89968"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/trending"
            app:layout_constraintBottom_toBottomOf="@id/trending"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTrending"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/trending"
            tools:listitem="@layout/item_product" />







    </androidx.constraintlayout.widget.ConstraintLayout>
    
</androidx.core.widget.NestedScrollView>